# Server Configuration
PORT=3000
BASE_URL=http://localhost:3000

# PostgreSQL Database Configuration
# For local testing, fill individual variables below.
# For production (e.g. Neon.tech), set DATABASE_URL (takes priority).
DATABASE_URL=your_neon_connection_string_here

DB_HOST=localhost
DB_PORT=5432
DB_NAME=identity_db
DB_USER=your_database_username
DB_PASSWORD=your_database_password

# Blockchain Configuration
# Tip: Use the first private key from `npx hardhat node` for local testing
BLOCKCHAIN_PRIVATE_KEY=your_hardhat_or_mainnet_private_key
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
